# ------- CLI / contract deploy (server-side, gitignored .env) -------
# Fresh, dedicated DEV wallet only. Never a production Clanker/Bankr key.
# Only needed for CLI --live deploys and scripts/deploy-live.sh.
# The mini app NEVER uses this: users sign with their own wallets.
PRIVATE_KEY=

# Optional: override the default Robinhood Chain RPC (also used by fork tests).
# ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
# RPC_URL=https://rpc.mainnet.chain.robinhood.com

# ------- Mini app (safe to expose; NEXT_PUBLIC_* is bundled client-side) -------
# RPC the app talks to: the Anvil fork for local testing, mainnet when live.
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Public base URL of the hosted app. EVERY absolute URL derives from this:
# share links, fc:miniapp embeds, the dynamic /.well-known/farcaster.json
# manifest, and image URLs. In production this MUST be the permanent domain
# (target: https://yodawg.xyz) — the signed Farcaster manifest is
# bound to this exact domain, so it cannot be an ephemeral tunnel.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enables the WalletConnect connector (free id: https://cloud.reown.com).
# Recommended for mobile users, since the Farcaster in-app wallet cannot reach
# Robinhood Chain and phones rarely have an injected wallet in the browser.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ------- Launcher registry storage (server-side) -------
# Default: JSON file at registry/launchers.json (local dev, CLI, any host
# with a persistent disk). On Vercel the filesystem is ephemeral, so set KV
# REST credentials and the registry switches to Vercel KV / Upstash Redis
# automatically. Both env-var conventions work (KV_REST_API_* is what the
# Vercel KV / Marketplace integration injects; UPSTASH_REDIS_REST_* is what
# the Upstash dashboard shows — same REST credentials):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ------- Farcaster manifest (server-side) -------
# The signed accountAssociation {header,payload,signature} JSON from
# https://farcaster.xyz/~/developers/mini-apps/manifest — signed with the
# owning account's Farcaster custody key for the EXACT production domain.
# Only the account owner can produce it; leave unset until then (the manifest
# route omits the key entirely rather than faking it).
# FARCASTER_ACCOUNT_ASSOCIATION={"header":"...","payload":"...","signature":"..."}

# OPTIONAL trustless mode only (unused by the shipped app): the on-chain
# LauncherLauncher wrapper address from scripts/fork-demo.sh / deploy-live.sh.
# NEXT_PUBLIC_LAUNCHER_LAUNCHER_ADDRESS=
