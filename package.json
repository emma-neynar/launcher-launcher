{
  "name": "launcher-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "A token-launcher-launcher on Robinhood Chain. Every token is force-paired with $HOODIE. Built on the published clanker-sdk (consumed read-only as an npm dependency).",
  "type": "module",
  "scripts": {
    "ll": "tsx src/cli.ts",
    "expected-position": "tsx src/cli.ts expected-position",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "fork:demo": "./scripts/fork-demo.sh",
    "test:contracts": "cd contracts && forge test",
    "deploy:live": "./scripts/deploy-live.sh"
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "0.3.0",
    "@farcaster/miniapp-wagmi-connector": "2.0.0",
    "@fontsource/anton": "^5.3.0",
    "@fontsource/comic-neue": "^5.3.0",
    "@tanstack/react-query": "^5.101.3",
    "@upstash/redis": "^1.38.0",
    "clanker-sdk": "^4.2.18",
    "commander": "^14.0.0",
    "dotenv": "^17.2.0",
    "next": "^16.2.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.55.4",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "axios": "^1.18.1",
    "postcss": "^8.5.10",
    "sharp": "^0.35.3",
    "viem": {
      "ws": "^8.21.0"
    }
  }
}
